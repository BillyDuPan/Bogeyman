{
  "hosting": {
    "site": "bogeyman",
    "public": "dist",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "cleanUrls": true,
    "rewrites": [
      {
        "source": "/mapmaker",
        "destination": "/mapmaker.html"
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  }
}
